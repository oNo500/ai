{
  "name": "@workspace/schema",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./api": "./src/api.d.ts",
    "./agentic": "./src/agentic.d.ts"
  },
  "scripts": {
    "gen": "pnpm gen:api && pnpm gen:agentic",
    "gen:api": "openapi-typescript http://localhost:3000/openapi-json -o src/api.d.ts",
    "gen:agentic": "openapi-typescript http://localhost:8000/openapi.json -o src/agentic.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
