# Environment Configuration
# Copy this file to .env and update the values

# --- Required ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agentic
RAG_COLLECTION=rag_documents

# --- LangSmith Observability (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=default

# --- Long-term Memory (Mem0) ---
# "memory" = in-process (default), "qdrant" = persistent
MEM0_VECTOR_STORE_PROVIDER=memory
MEM0_QDRANT_URL=http://localhost:6333
MEM0_QDRANT_COLLECTION=mem0

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
