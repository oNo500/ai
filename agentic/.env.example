# Python Agentic service — service-specific variables
# Shared variables (DATABASE_URL, REDIS_URL, OPENAI_API_KEY, OPENAI_MODEL, LANGSMITH_*)
# are managed in root .env — do not duplicate them here

# --- RAG / pgvector ───────────────────────────────────────
RAG_COLLECTION=rag_documents

# --- Long-term Memory (Mem0) ──────────────────────────────
# "memory" = in-process (default), "qdrant" = persistent
MEM0_VECTOR_STORE_PROVIDER=memory
MEM0_QDRANT_URL=http://localhost:6333
MEM0_QDRANT_COLLECTION=mem0

# --- Rate Limiting ────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
